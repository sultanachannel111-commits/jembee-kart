"use client";

import { useEffect, useState } from "react";
import { collection, getDocs } from "firebase/firestore";
import { db } from "@/lib/firebase";

export default function DiagnosticsPage(){

const [report,setReport] = useState<any>({
banners:0,
festival:0,
categories:0,
products:0,
missingProductImages:0,
missingCategoryImages:0
});

useEffect(()=>{

const runCheck = async()=>{

const banners = await getDocs(collection(db,"banners"));
const festival = await getDocs(collection(db,"offers"));
const categories = await getDocs(collection(db,"categories"));
const products = await getDocs(collection(db,"products"));

let missingProductImages = 0;
let missingCategoryImages = 0;

products.docs.forEach(doc=>{
const data:any = doc.data();
if(!data.image){
missingProductImages++;
}
});

categories.docs.forEach(doc=>{
const data:any = doc.data();
if(!data.image){
missingCategoryImages++;
}
});

setReport({
banners:banners.size,
festival:festival.size,
categories:categories.size,
products:products.size,
missingProductImages,
missingCategoryImages
});

};

runCheck();

},[]);

return(

<div className="p-6"><h1 className="text-2xl font-bold mb-6">
JembeeKart System Diagnostics
</h1><div className="space-y-4"><div className="border p-4 rounded">
Banners Found: {report.banners}
</div><div className="border p-4 rounded">
Festival Banners: {report.festival}
</div><div className="border p-4 rounded">
Categories: {report.categories}
</div><div className="border p-4 rounded">
Products: {report.products}
</div><div className="border p-4 rounded text-red-500">
Missing Product Images: {report.missingProductImages}
</div><div className="border p-4 rounded text-red-500">
Missing Category Images: {report.missingCategoryImages}
</div></div></div>);

}
